# Unity Catalog Configuration (required for Unity Catalog tables)
DATABRICKS_WORKSPACE_URL=your-databricks-workspace-url
DATABRICKS_TOKEN=your-databricks-token

# Azure Storage Configuration
# For Unity Catalog: AZURE_STORAGE_ACCOUNT_NAME is optional (retrieved from API)
# For direct ABFSS paths: both variables below are required
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
# AZURE_STORAGE_SAS_TOKEN=your-sas-token-without-leading-question-mark

# Table Configuration
TABLE=your-table-name